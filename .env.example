# =============================================================================
# FRONTEND — variáveis expostas ao browser (prefixo VITE_)
# =============================================================================

# ID do projeto Supabase (encontrado em Project Settings > General)
VITE_SUPABASE_PROJECT_ID=your-project-id

# URL pública do projeto Supabase (ex: https://xyzxyz.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Chave anon/public do Supabase (Project Settings > API > Project API keys)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...

# DSN do Sentry para captura de erros no frontend (sentry.io > Settings > Projects > Client Keys)
VITE_SENTRY_DSN=https://...@sentry.io/...

# =============================================================================
# EDGE FUNCTIONS — variáveis injetadas no Supabase (Project Settings > Edge Functions)
# As três primeiras são injetadas automaticamente pelo Supabase — não precisam ser setadas
# =============================================================================

# Injetado automaticamente pelo Supabase
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Token da Apify para scraping do Instagram (apify.com > Settings > Integrations)
APIFY_API_TOKEN=apify_api_...

# Chave da API Anthropic/Claude (console.anthropic.com > API Keys)
ANTHROPIC_API_KEY=sk-ant-...

# Resend — envio de emails transacionais (resend.com > API Keys)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@axtor.space

# Asaas — gateway de pagamentos (sandbox: $aact_hmlg_..., produção: $aact_prod_...)
ASAAS_API_KEY=$aact_...
ASAAS_WEBHOOK_TOKEN=seu-token-secreto-de-webhook

# Lovable — usado em funções de geração de ícone e templates de email
LOVABLE_API_KEY=...

# DSN do Sentry para captura de erros nas edge functions (mesmo projeto, DSN sem prefixo VITE_)
SENTRY_DSN=https://...@sentry.io/...
